# Required environment variables for Strader
# Copy to .env and fill in values.

SCHWAB_API_KEY=  # Schwab API key from https://developer.schwab.com (required)
SCHWAB_APP_SECRET=  # Schwab app secret from https://developer.schwab.com (required)
SCHWAB_CALLBACK_URL=https://127.0.0.1:8182/  # OAuth callback URL configured in Schwab app
SCHWAB_TOKEN_PATH=./tokens/schwab_token.json  # Path to store OAuth tokens
