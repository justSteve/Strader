{
  "permissions": {
    "allow": [
      "Edit(*)",
      "Write(*)",
      "MultiEdit(*)",
      "Read(*)",
      "Glob(*)",
      "Grep(*)",
      "Bash(cd *)",
      "Bash(echo *)",
      "Bash(pwd *)",
      "Bash(which *)",
      "Bash(test *)",
      "Bash(sleep *)",
      "Bash(true *)",
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(gt *)",
      "Bash(bd *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(python3 *)",
      "Bash(curl *)",
      "Bash(bash *)",
      "Bash(sh *)",
      "Bash(source *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(rm *)",
      "Bash(touch *)",
      "Bash(chmod *)",
      "Bash(mkdir *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(sed *)",
      "Bash(awk *)",
      "Bash(sort *)",
      "Bash(diff *)",
      "Bash(xargs *)",
      "Bash(jq *)",
      "Bash(timeout *)",
      "Bash(tee *)",
      "mcp__fetch__fetch",
      "mcp__github__*"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/*credentials*)",
      "Read(**/*secret*)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Edit(**/.env)",
      "Edit(**/.env.*)"
    ]
  },
  "mcpServers": {
    "tradestation": {
      "command": "npx",
      "args": [
        "-y",
        "@tradestation/mcp-server"
      ],
      "env": {
        "TS_API_KEY": "${TS_API_KEY}",
        "TS_API_SECRET": "${TS_API_SECRET}"
      },
      "type": "stdio"
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "/root/projects/gtOps/ECC/hooks/perm-audit-hook.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "inotifywait -m -e modify /var/moo/strader/positions.jsonl",
            "description": "position-change-alert: position-change-alert: position-change-alert: Reactive: position-change-alert (file_change)"
          },
          {
            "type": "command",
            "command": "claude --skill greeks-analysis",
            "description": "position-change-alert: position-change-alert: position-change-alert: Reactive: position-change-alert (file_change)"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "claude --skill risk-limit-enforcement",
            "description": "risk-breach: risk-breach: Reactive: risk-breach (skill_output)"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "claude --skill entry-signal-evaluation --context \"Incoming market intel from Discord. Evaluate for actionable trade setups. Cross-reference with current positions.\"",
            "description": "discord-intel: Reactive: discord-intel (channel_message)"
          }
        ],
        "matcher": "capability == \"discord-intel\""
      }
    ]
  }
}
