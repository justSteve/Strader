{
  "hooks": [
    {
      "id": "domain-factory/position-change-alert",
      "pluginId": "strader",
      "name": "position-change-alert",
      "description": "Reactive: position-change-alert (file_change)",
      "eventType": "PostToolUse",
      "matcher": "*",
      "enabled": true,
      "priority": 10,
      "actions": [
        {
          "id": "action-position-change-alert-watch",
          "hookId": "domain-factory/position-change-alert",
          "actionType": "command",
          "command": "inotifywait -m -e modify /var/moo/strader/positions.jsonl",
          "actionOrder": 1
        },
        {
          "id": "action-position-change-alert-invoke",
          "hookId": "domain-factory/position-change-alert",
          "actionType": "command",
          "command": "claude --skill greeks-analysis",
          "actionOrder": 2
        }
      ]
    },
    {
      "id": "domain-factory/risk-breach",
      "pluginId": "strader",
      "name": "risk-breach",
      "description": "Reactive: risk-breach (skill_output)",
      "eventType": "PostToolUse",
      "matcher": "*",
      "enabled": true,
      "priority": 1,
      "actions": [
        {
          "id": "action-risk-breach-invoke",
          "hookId": "domain-factory/risk-breach",
          "actionType": "command",
          "command": "claude --skill risk-limit-enforcement",
          "actionOrder": 1
        }
      ]
    },
    {
      "id": "domain-factory/discord-intel",
      "pluginId": "strader",
      "name": "discord-intel",
      "description": "Reactive: discord-intel (channel_message)",
      "eventType": "Notification",
      "matcher": "capability == \"discord-intel\"",
      "enabled": true,
      "priority": 10,
      "actions": [
        {
          "id": "action-discord-intel-invoke",
          "hookId": "domain-factory/discord-intel",
          "actionType": "command",
          "command": "claude --skill entry-signal-evaluation --context \"Incoming market intel from Discord. Evaluate for actionable trade setups. Cross-reference with current positions.\"",
          "actionOrder": 1
        }
      ]
    }
  ],
  "mcpServers": {
    "tradestation": {
      "command": "npx",
      "args": [
        "-y",
        "@tradestation/mcp-server"
      ],
      "env": {
        "TS_API_KEY": "${TS_API_KEY}",
        "TS_API_SECRET": "${TS_API_SECRET}"
      },
      "type": "stdio"
    }
  }
}
