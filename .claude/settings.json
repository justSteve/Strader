{
  "permissions": {
    "allow": [
      "Edit(*)",
      "Write(*)",
      "MultiEdit(*)",
      "Bash(cd *)",
      "Bash(echo *)",
      "Bash(pwd *)",
      "Bash(which *)",
      "Bash(test *)",
      "Bash(sleep *)",
      "Bash(true *)",
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(gt *)",
      "Bash(bd *)",
      "Bash(bun *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(curl *)",
      "Bash(bash *)",
      "Bash(sh *)",
      "Bash(source *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(rm *)",
      "Bash(touch *)",
      "Bash(chmod *)",
      "Bash(mkdir *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(sed *)",
      "Bash(awk *)",
      "Bash(sort *)",
      "Bash(diff *)",
      "Bash(xargs *)",
      "Bash(jq *)",
      "Bash(timeout *)",
      "Bash(tee *)",
      "mcp__fetch__fetch",
      "mcp__github__*",
      "Read(*)",
      "Glob(*)",
      "Grep(*)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/*credentials*)",
      "Read(**/*secret*)",
      "Read(//**/id_rsa)",
      "Read(//**/id_ed25519)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Edit(**/.env)",
      "Edit(**/.env.*)"
    ]
  },
  "mcpServers": {
    "tradestation": {
      "command": "npx",
      "args": [
        "-y",
        "@tradestation/mcp-server"
      ],
      "env": {
        "TS_API_KEY": "${TS_API_KEY}",
        "TS_API_SECRET": "${TS_API_SECRET}"
      },
      "type": "stdio"
    }
  }
}
