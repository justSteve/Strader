# Auto detect text files and perform LF normalization
* text=auto

# JS/TS
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf

# Python
*.py text eol=lf

# Config
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.cfg text eol=lf
*.ini text eol=lf

# Docker
Dockerfile text eol=lf
docker-compose*.yml text eol=lf

# SQL
*.sql text eol=lf

# Markdown
*.md text eol=lf

# Shell
*.sh text eol=lf

# Binary
*.png binary
*.jpg binary
*.ico binary
*.woff binary
*.woff2 binary
