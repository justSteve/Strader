# Schwab API credentials (required for live data)
STRADER_SCHWAB_APP_KEY=your_app_key
STRADER_SCHWAB_APP_SECRET=your_app_secret
STRADER_SCHWAB_CALLBACK_URL=https://127.0.0.1:8443/callback

# Risk limits
STRADER_MAX_DAILY_LOSS=5000
STRADER_MAX_POSITION_COUNT=10
STRADER_MAX_SINGLE_POSITION_NOTIONAL=5000
STRADER_MAX_PORTFOLIO_DELTA=50
STRADER_RISK_PER_TRADE_PCT=2
